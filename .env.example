# Backend
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/auth/spotify/callback
GEMINI_API_KEY=your-gemini-api-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Frontend
VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Frontend optional overrides
VITE_GRAPH_ENDPOINT=/api/graph/generate
VITE_SPOTIFY_AUTH_START_ENDPOINT=/api/auth/spotify/login
VITE_USE_GRAPH_FIXTURE=false
